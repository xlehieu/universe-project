// ============================================================
// Prisma Schema — Planet Service
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUM — định nghĩa trước model
// ============================================================

enum PlanetType {
  terrestrial  // Hành tinh đất đá (Earth, Mars)
  gas_giant    // Sao khí khổng lồ (Jupiter, Saturn)
  ice_giant    // Sao băng khổng lồ (Uranus, Neptune)
  dwarf        // Hành tinh lùn (Pluto)
  super_earth  // Siêu Trái Đất
  sub_earth    // Nhỏ hơn Trái Đất
}

// ============================================================
// MODEL
// ============================================================

model Planet {
  // --- Primary Key ---
  id  String  @id @default(uuid()) @db.Uuid

  // --- Thông tin cơ bản ---
  name         String
  type         PlanetType
  description  String?

  // --- Vị trí trong không gian (x, y, z) ---
  position_x  Float  // đơn vị AU
  position_y  Float
  position_z  Float

  // --- Quỹ đạo ---
  orbital_radius_au    Float   // bán kính quỹ đạo (AU)
  orbital_period_days  Float   // chu kỳ quỹ đạo (ngày)

  // --- Vật lý ---
  rotation_period_hours  Float?  // âm = quay ngược chiều
  radius_km              Float
  mass_kg                Float?
  gravity_ms2            Float?

  // --- Môi trường ---
  atmosphere  String?
  temp_min    Float?
  temp_max    Float?
  habitable   Boolean  @default(false)

  // --- Vành đai ---
  rings                Boolean  @default(false)
  ring_inner_radius_km Float?
  ring_outer_radius_km Float?
  ring_color_hex       String?

  // --- Visual ---
  color_hex  String?
  texture    String?

  // --- Quan hệ với Moon (cùng service) ---
  moons       Moon[]
  moons_count Int     @default(0)

  // --- Foreign key sang Solar System Service (khác service, không có relation thật) ---
  solar_system_id  String  @db.Uuid

  // --- Timestamps ---
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  @@map("planets")
}

model Moon {
  // --- Primary Key ---
  id  String  @id @default(uuid()) @db.Uuid

  // --- Thông tin cơ bản ---
  name     String
  texture  String?

  // --- Vật lý ---
  orbital_radius_km  Float
  radius_km          Float

  // --- Visual ---
  color_hex  String?

  // --- Quan hệ với Planet (cùng service, có relation thật) ---
  planet_id  String  @db.Uuid
  planet     Planet  @relation(fields: [planet_id], references: [id], onDelete: Cascade)

  // --- Timestamps ---
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  @@map("moons")
}